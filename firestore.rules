rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // セッション: 読み取り自由、書き込み自由（プロトタイプ段階）
    // 本番化時はAdminのみ書き込み可能に変更すること
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if true;
    }

    // マスタアイテム: 読み取り自由
    match /masterItems/{itemId} {
      allow read: if true;
      allow write: if true;
    }

    // 計数レコード: 読み取り・書き込み自由（プロトタイプ段階）
    match /countRecords/{recordId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
